# Copy to .env and fill in.

# HuggingFace token for model downloads.
HF_TOKEN=

# The model id you actually serve. Must match whatever you pass to vLLM
# via scripts/start_vllm.sh - if you serve an FP8 / AWQ / GPTQ variant,
# the model id here changes accordingly. The agent uses this for its
# chat-completions requests.
VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507

# Optional: point the agent at any OpenAI-compatible API so you can build and
# debug the Phase 3 graph without a running vLLM. Uncomment and fill in, then
# switch back to the defaults for final prompt tuning and all of Phases 5-6.
# VLLM_BASE_URL=https://api.openai.com/v1
# VLLM_MODEL=gpt-4o-mini
# OPENAI_API_KEY=sk-...

# Alternative used during development: Nebius Token Factory (serves the real
# Qwen3-30B-A3B). Get a key at https://tokenfactory.nebius.com -> API Keys.
# The agent reads OPENAI_API_KEY, so point it at the Nebius key. Note: a hosted
# API exposes no Prometheus /metrics, so Phases 2/6 still need the H100 vLLM.
# VLLM_BASE_URL=https://api.tokenfactory.nebius.com/v1
# VLLM_MODEL=Qwen/Qwen3-30B-A3B-Instruct-2507
# NEBIUS_API_KEY=
# OPENAI_API_KEY=${NEBIUS_API_KEY}

# Langfuse keys (Phase 4). These are per-instance: after `docker compose up -d`,
# open http://localhost:3001 -> sign up -> create a project -> Settings ->
# API Keys, then paste the pk-lf-/sk-lf- values below. A fresh Langfuse (e.g. on
# the VM) generates NEW keys, so don't hardcode them here - keep this file blank.
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=http://localhost:3001
